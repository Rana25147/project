# Identity Security Framework — Environment Configuration
# Copy this file to .env and fill in production values before deploying.
# Never commit .env to version control.

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development

# ── Cryptography (shared for Flask session + JWT signing) ─────────────────────
SECRET_KEY=super_secret_crypto_string_x98_2026!

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=database.db

# ── Brute-force protection ────────────────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
BLOCK_WINDOW_MINUTES=15

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_EXP_DELTA_MINS=60

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_LIFETIME_SECONDS=3600
SESSION_COOKIE_SECURE=False

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=AdminSecret123!
